model Product {
    id      String @unique @default(uuid()) @db.Uuid
    storeId String @db.Uuid
    store   Store  @relation(fields: [storeId], references: [id])

    name        String
    sku         String? // Barcode dari toko tersebut
    description String?
    image       String?

    stock    Int @default(0)
    minStock Int @default(0)

    categoryId String?          @db.Uuid
    category   ProductCategory? @relation(fields: [categoryId], references: [id])

    unitId String      @db.Uuid
    unit   ProductUnit @relation(fields: [unitId], references: [id])

    createdAt DateTime   @default(now()) @db.Timestamptz()
    updatedAt DateTime   @updatedAt @db.Timestamptz()
    deletedAt DateTime?  @db.Timestamptz()
    stockLogs StockLog[]

    createdById String @db.Uuid
    createdBy   User   @relation("ProductCreatedBy", fields: [createdById], references: [id])

    updatedById String? @db.Uuid
    updatedBy   User?   @relation("ProductUpdatedBy", fields: [updatedById], references: [id])

    @@unique([storeId, sku])
    @@index([storeId])
    @@map("products")
}

model ProductCategory {
    id          String  @id @unique @default(uuid()) @db.Uuid
    name        String
    description String?

    storeId String @db.Uuid
    store   Store  @relation(fields: [storeId], references: [id])

    parentId String?           @db.Uuid
    parent   ProductCategory?  @relation("CategoryToSub", fields: [parentId], references: [id])
    children ProductCategory[] @relation("CategoryToSub")

    products Product[]

    createdAt DateTime  @default(now()) @db.Timestamptz()
    updatedAt DateTime? @updatedAt @db.Timestamptz()
    deletedAt DateTime? @db.Timestamptz()

    @@map("product_categories")
}

model ProductUnit {
    id      String @id @default(uuid()) @db.Uuid
    storeId String @db.Uuid
    store   Store  @relation(fields: [storeId], references: [id])

    name  String // "Kilogram", "Lusin", dll
    value String // "kg", "lusin", dll — dipakai di kolom unit product

    createdAt DateTime @default(now()) @db.Timestamptz()
    updatedAt DateTime @updatedAt @db.Timestamptz()

    products Product[]

    @@unique([storeId, value])
    @@index([storeId])
    @@map("product_units")
}

model StockLog {
    id        String  @id @default(uuid()) @db.Uuid
    productId String  @db.Uuid
    product   Product @relation(fields: [productId], references: [id])

    storeId String @db.Uuid
    store   Store  @relation(fields: [storeId], references: [id])

    userId String @db.Uuid
    user   User   @relation(fields: [userId], references: [id])

    // Perubahan stok (bisa positif atau negatif)
    quantity    Int
    resultStock Int // Stok akhir SETELAH perubahan (Saldo)

    // Alasan perubahan
    type      StockLogType
    // Catatan tambahan (misal: "Barang jatuh pecah", atau "Bonus dari supplier")
    notes     String?
    createdAt DateTime     @default(now()) @db.Timestamptz()

    @@index([productId])
    @@map("stock_logs")
}

enum StockLogType {
    SALE // Terjual lewat kasir
    PURCHASE // Kita beli barang dari supplier (restock)
    ADJUSTMENT // Penyesuaian manual (misal: pas opname stok ternyata beda)
    WASTE // Barang rusak, hilang, atau expired
    RETURN // Barang dikembalikan oleh pembeli
    ARCHIVED // Barang dihapus
}
