model User {
  id      String  @id @default(uuid()) @db.Uuid
  name    String?
  email   String  @unique
  picture String?
  role    String  @default("user")

  provider   String?
  providerId String? @unique

  createdAt DateTime  @default(now()) @db.Timestamptz()
  updatedAt DateTime  @updatedAt @db.Timestamptz()
  deletedAt DateTime? @db.Timestamptz()

  stores     Store[]
  storeUsers StoreUser[]

  @@map("users")
  stockLogs StockLog[]
  createdProducts Product[] @relation("ProductCreatedBy")
  updatedProducts Product[] @relation("ProductUpdatedBy")
  
  activityLogs ActivityLog[]
  sessions Session[]

  createdProductCategories ProductCategory[] @relation("ProductCreatedBy")
  updatedProductCategories ProductCategory[] @relation("ProductUpdatedBy")
}

model StoreUser {
  id   String @id @default(uuid()) @db.Uuid
  role String @default("crew")

  userId  String @db.Uuid
  storeId String @db.Uuid

  user  User  @relation(fields: [userId], references: [id])
  store Store @relation(fields: [storeId], references: [id])

  @@unique([userId, storeId])
  @@map("store_users")
}

model Session {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  jti         String    @unique
  device      String?
  ipAddress   String?
  lastUsedAt  DateTime  @default(now()) @db.Timestamptz()
  expiresAt   DateTime  @db.Timestamptz()
  createdAt   DateTime  @default(now()) @db.Timestamptz()

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([jti])
  @@map("sessions")
}